FROM alpine:3.24 AS builder

RUN apk add nodejs npm python3 py3-pip

# WARP Python dependencies
WORKDIR /warp
COPY requirements.txt .
RUN pip wheel -w wheel -r requirements.txt \
    && rm -f wheel/lxml-*.whl wheel/xmlsec-*.whl

# webpack dependencies
WORKDIR /warp/js
COPY js/package.json js/package-lock.json js/webpack.config.js .
RUN npm ci

# build
COPY js/views/ views/
COPY js/base/ base/
RUN npm run build

# copy warp and build it as a module
WORKDIR /warp
COPY setup.py MANIFEST.in .
COPY warp/ warp/
RUN pip wheel -w wheel --no-deps .

FROM alpine:3.24

# Sane default; override via -e TZ=Europe/Warsaw at runtime
ENV TZ=UTC

RUN apk add python3 py3-pip postgresql18 \
    # tzdata is required by Python zoneinfo (and localtime()) on musl/Alpine
    tzdata \
    # Alpine-native py3-lxml/py3-xmlsec share the same libxml2.so as uWSGI (no version mismatch)
    py3-lxml py3-xmlsec libxslt
RUN \
    --mount=type=bind,from=builder,source=/warp/wheel,target=./wheel \
    pip install --break-system-packages --no-index --no-deps wheel/*.whl
RUN \
  install -d -m 700 -o postgres -g postgres /pgdata \
  && install -d -m 755 -o postgres -g postgres /run/postgresql \
  && echo "postgres_password" > /tmp/postgres_pass \
  && su postgres -c "initdb \
      -D /pgdata \
      --locale=C.UTF-8 \
      --encoding=UTF8 \
      --auth-local=peer \
      --auth-host=scram-sha-256 \
      --pwfile=/tmp/postgres_pass \
      -c listen_addresses='localhost' \
      -c autovacuum=off \
      -c max_worker_processes=2 \
      -c max_parallel_workers=0 \
      -c max_parallel_workers_per_gather=0 \
      -c max_parallel_maintenance_workers=0 \
      -c max_wal_senders=0 \
      -c wal_level=minimal \
      -c shared_buffers=16MB \
      -c max_connections=20 \
      -c fsync=off \
      -c synchronous_commit=off" \
  && echo "host all all 0.0.0.0/0 scram-sha-256" >> /pgdata/pg_hba.conf \
  && rm /tmp/postgres_pass

# Postgres listens on localhost only by default — even with `-p 5432:5432` the
# docker/podman proxy connects to the container IP, so the database stays
# unreachable from outside. Set EXPOSE_POSTGRES=1 (and publish 5432) to bind it
# to all interfaces for interactive debugging.
COPY <<'EOF' /usr/local/bin/start-postgres.sh
#!/bin/sh
addr=localhost
[ -n "$EXPOSE_POSTGRES" ] && addr='*'
exec /bin/su - postgres -c "/usr/bin/postgres -D /pgdata -c listen_addresses='$addr'"
EOF
RUN chmod +x /usr/local/bin/start-postgres.sh

COPY <<EOF /etc/inittab
#::sysinit:/etc/rc.local
::respawn:/usr/local/bin/start-postgres.sh
::respawn:/usr/bin/flask --app=warp --debug run --host=0.0.0.0
::shutdown:/bin/echo "Shutting down..."
EOF

EXPOSE 5000/tcp 5432/tcp
STOPSIGNAL SIGUSR2
ENTRYPOINT ["/sbin/init"]
